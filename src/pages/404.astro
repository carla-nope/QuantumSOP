---
import Base from "../layouts/Base.astro";
---

<Base
  title="Page Not Found"
  description="This page does not exist. Return to QuantumSOP."
  docId="QSOP-WEB-404"
>
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">HTTP 404 · Record Not Located</p>
      <h1>This document isn't in the file.</h1>
      <p class="lede">The page you requested doesn't exist or has been moved.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/">Return home</a>
        <a class="btn btn-secondary" href="/start-here">Start here</a>
      </div>
    </div>
  </section>
</Base>
